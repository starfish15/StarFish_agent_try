DEEPSEEK_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
MAX_ITERATIONS=5

# 可选：分别控制启用哪些 tools / skills（逗号分隔；不填则使用内置默认全部启用）
# ENABLED_TOOLS=get_weather,calculate
# ENABLED_SKILLS=cat_persona,llm_tuning,json_tool_calling

# 可选：通过 skill 调优 LLM 参数（不填则使用代码默认值）
# SKILL_TEMPERATURE=0.0
# SKILL_MODEL=deepseek-v4-flash

# 可选：启用“Markdown 文件式 skills”（类似用一份提示词文件来管理技能）
# LOAD_FILE_SKILLS=1
# SKILL_DEFINITIONS_DIR=skills/definitions